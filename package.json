{
  "name": "capyfin",
  "private": true,
  "version": "0.1.2",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "turbo run build",
    "cli": "pnpm --filter @capyfin/cli cli",
    "desktop:build": "pnpm --filter @capyfin/desktop tauri build",
    "desktop:dev": "pnpm --filter @capyfin/desktop tauri dev",
    "dev": "node scripts/dev-browser.mjs",
    "dev:frontend": "pnpm --filter @capyfin/desktop dev",
    "sidecar:bundle": "pnpm --filter @capyfin/sidecar bundle:prepare",
    "sidecar:build": "pnpm --filter @capyfin/sidecar build",
    "sidecar:dev": "pnpm --filter @capyfin/sidecar dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo run lint",
    "release:check-version": "node scripts/sync-version.mjs --check",
    "release:sync-version": "node scripts/sync-version.mjs",
    "rust:check": "cargo check --workspace",
    "rust:clippy": "cargo clippy --workspace --all-targets -- -D warnings",
    "rust:fmt": "cargo fmt --all",
    "rust:fmt:check": "cargo fmt --all --check",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.4.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "turbo": "^2.8.16",
    "typescript-eslint": "^8.57.0"
  }
}
