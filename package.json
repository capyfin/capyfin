{
  "name": "capyfin",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "turbo run build",
    "desktop:build": "pnpm --filter @capyfin/desktop tauri build",
    "desktop:dev": "pnpm --filter @capyfin/desktop tauri dev",
    "dev": "pnpm --filter @capyfin/desktop dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo run lint",
    "rust:check": "cargo check --manifest-path apps/desktop/src-tauri/Cargo.toml",
    "rust:clippy": "cargo clippy --manifest-path apps/desktop/src-tauri/Cargo.toml --all-targets -- -D warnings",
    "rust:fmt": "cargo fmt --all --manifest-path apps/desktop/src-tauri/Cargo.toml",
    "rust:fmt:check": "cargo fmt --all --check --manifest-path apps/desktop/src-tauri/Cargo.toml",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.16",
    "typescript-eslint": "^8.57.0"
  }
}
