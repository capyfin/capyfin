{
  "name": "@capyfin/cli",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "capyfin": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "cli": "tsx src/index.ts",
    "lint": "eslint src --ext .ts",
    "test": "tsx --test src/**/*.test.ts",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@capyfin/contracts": "workspace:*",
    "@capyfin/core": "workspace:*",
    "@capyfin/sidecar": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
