{
  "name": "@capyfin/sidecar",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "dev": "tsx src/cli.ts",
    "lint": "eslint src --ext .ts",
    "test": "tsx --test src/auth/*.test.ts src/server/routes/*.test.ts",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@capyfin/core": "workspace:*",
    "@hono/node-server": "^1.19.11",
    "@mariozechner/pi-ai": "^0.57.1",
    "hono": "^4.12.7"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
